#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Running pre-push checks..."

# Run lint
echo "Running ESLint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "ESLint failed. Please fix the errors before pushing."
  exit 1
fi

# Run type check
echo "Running TypeScript type check..."
npm run typecheck
if [ $? -ne 0 ]; then
  echo "TypeScript type check failed. Please fix the errors before pushing."
  exit 1
fi

# Run tests
echo "Running tests..."
npm run test:ci
if [ $? -ne 0 ]; then
  echo "Tests failed. Please fix the failing tests before pushing."
  exit 1
fi

echo "All pre-push checks passed!"
