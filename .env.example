# Copy to .env and fill in. EXPO_PUBLIC_* vars are inlined into the client
# bundle at build time (safe only for publishable/public values). Set the same
# vars in your EAS build environment for production builds.

# Supabase (publishable key — safe to ship in a client app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Mapbox access token
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxx

# Resend API key — server-side only, used by the send-suggestion API route.
# NOT prefixed with EXPO_PUBLIC_ so it is never bundled into the client.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
