{
  "expo": {
    "name": "Sportinkaart",
    "slug": "Sportinkaart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sportinkaart",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sportinkaart.app",
      "buildNumber": "1.0",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app does not access your photo library.",
        "NSCameraUsageDescription": "This app does not access your camera.",
        "NSLocationWhenInUseUsageDescription": "We gebruiken je locatie om sportlocaties in de buurt te kunnen tonen.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "package": "com.sportinkaart.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-sportinkaart.png",
          "resizeMode": "cover",
          "backgroundColor": "#1a1a1a"
        }
      ],
      "expo-font",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "776798a7-d998-4476-bc86-753317151ae4"
      }
    }
  }
}
